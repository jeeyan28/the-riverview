import { useEffect, useState } from 'react';
import { Outlet } from 'react-router-dom';
import '../styles/style.css';
import '../styles/enhancements.css';
import '../styles/auth-ui.css';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import ProfileModal from '../components/ProfileModal';

// ─────────────────────────────────────────────────────────────────────────
// MainLayout — the public "marketing site" shell. Phase 6 built this with
// the header/promo-banner/mobile-nav/footer markup all inline; Phase 7
// extracted that markup out into <Navbar/> and <Footer/> (src/components/),
// per the plan in components/README.md. This file now only owns the
// STATE (theme, promo visibility, mobile nav open/closed, scrolled) and
// passes it down as props — no visual/behavioral change from Phase 6.
//
// PHASE 8 (part 3) ADDITION: also owns whether <ProfileModal/> is open,
// for the same reason it already owns Navbar's other state — Navbar's
// "My Profile" button lives in the header this layout renders on every
// page it wraps, so the modal it opens belongs here too, not in any one
// page. See components/ProfileModal.jsx's header comment for the full
// reasoning. `styles/auth-ui.css` is imported here for the first time —
// it holds the `.user-chip-menu.open` display rule the chip's dropdown
// now depends on (see Navbar.jsx's Phase 8 comment); `.pf-*` profile-modal
// classes were already available via style.css/enhancements.css, imported
// above since Phase 6.
//
// Still NOT done (unchanged from Phase 6, deferred to later phases):
//   - Real logged-in/logged-out header state — Phase 10 (AuthContext).
//   - Live announcement banner text from GET /api/settings — Phase 8/9.
// ─────────────────────────────────────────────────────────────────────────

const PROMO_DISMISS_KEY = 'riverview-promo-dismissed';
const THEME_KEY = 'riverview-theme';

function MainLayout() {
  const [theme, setTheme] = useState(
    () => document.documentElement.getAttribute('data-theme') || 'light'
  );
  const [promoVisible, setPromoVisible] = useState(
    () => sessionStorage.getItem(PROMO_DISMISS_KEY) !== '1'
  );
  const [mobileNavOpen, setMobileNavOpen] = useState(false);
  const [scrolled, setScrolled] = useState(false);
  const [profileOpen, setProfileOpen] = useState(false);

  // Theme toggle — same localStorage key ('riverview-theme') as the old
  // inline <script> in index.html's <head>, so a preference saved before
  // the React migration still applies.
  useEffect(() => {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem(THEME_KEY, theme);
  }, [theme]);

  function toggleTheme() {
    setTheme((t) => (t === 'dark' ? 'light' : 'dark'));
  }

  // Keeps --banner-h in sync so the page content below the fixed header
  // doesn't jump/overlap when the banner is dismissed. Mirrors
  // setBannerHeightVar() from the old index.js.
  useEffect(() => {
    const banner = document.getElementById('promo-banner');
    const h = promoVisible && banner ? banner.offsetHeight : 0;
    document.documentElement.style.setProperty('--banner-h', `${h}px`);
  }, [promoVisible]);

  function dismissPromo() {
    setPromoVisible(false);
    sessionStorage.setItem(PROMO_DISMISS_KEY, '1');
  }

  // Header "scrolled" shadow/background state.
  useEffect(() => {
    function onScroll() {
      setScrolled(window.scrollY > 40);
    }
    window.addEventListener('scroll', onScroll);
    return () => window.removeEventListener('scroll', onScroll);
  }, []);

  // Prevent body scroll while the mobile nav drawer is open.
  useEffect(() => {
    document.body.style.overflow = mobileNavOpen ? 'hidden' : '';
  }, [mobileNavOpen]);

  return (
    <>
      <Navbar
        theme={theme}
        onToggleTheme={toggleTheme}
        promoVisible={promoVisible}
        onDismissPromo={dismissPromo}
        mobileNavOpen={mobileNavOpen}
        onOpenMobileNav={() => setMobileNavOpen(true)}
        onCloseMobileNav={() => setMobileNavOpen(false)}
        scrolled={scrolled}
        onOpenProfile={() => setProfileOpen(true)}
      />

      <main>
        <Outlet />
      </main>

      <Footer />

      <ProfileModal open={profileOpen} onClose={() => setProfileOpen(false)} />
    </>
  );
}

export default MainLayout;
