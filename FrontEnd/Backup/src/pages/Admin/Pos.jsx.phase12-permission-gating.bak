import { useCallback, useEffect, useState } from 'react';
import DataTable from '../../components/DataTable';

// ─────────────────────────────────────────────────────────────────────────
// Admin / POS (Point of Sale) — migrated from admin.html's
// <div id="panel-pos"> plus admin.js's "POS (POINT OF SALE)" section
// (posSubtotal, renderPosCart, removePosItem, the #pos-add-item-btn
// listener, fetchPosSalesToday, posSaleRowHtml, renderPosSalesTable,
// voidPosSale, the #pos-checkout-btn listener, renderPOS). Part of
// Phase 8 (Page Migration), continuing after Admin Dashboard, Bookings,
// and Room Monitor.
//
// As the original's own comment on this section says: this is a simple
// line-item register, not a product catalog / inventory system — staff
// type an item name/price/qty, it goes into an in-memory cart, and
// "Complete Sale" posts the whole cart to POST /api/pos/sales in one call.
// That in-memory-cart model is kept exactly as-is here, just as React
// state (`cart`) instead of a module-level `let posCart = []`.
//
// All 3 backend endpoints this page calls are unchanged from the original:
//   GET  /api/pos/sales?date=YYYY-MM-DD   (today's transactions list)
//   POST /api/pos/sales                    (complete a sale)
//   PUT  /api/pos/sales/:id/void            (void a sale)
//
// Behavior preserved 1:1:
//   - Adding a cart item requires a non-empty name and a valid non-negative
//     price; qty is clamped to a minimum of 1 (same validation as the
//     original's #pos-add-item-btn listener).
//   - Subtotal = sum(price * qty); Total = max(0, subtotal - discount) —
//     same as posSubtotal()/renderPosCart()'s inline total math.
//   - "Today" is computed client-side as a local YYYY-MM-DD string (not
//     UTC), matching the original's fetchPosSalesToday() date construction
//     exactly, so the query lines up with the server's expectations the
//     same way it always did.
//   - Voided sales show a "Voided" pill (pill-pending) vs. "Completed"
//     (pill-active) — this exact pairing, not swapped, matches the
//     original's posSaleRowHtml() (Voided intentionally used the pending/
//     amber pill, not the muted/done one).
//   - Completing a sale clears the cart, resets discount to 0 and note to
//     '', then reloads today's transactions — same as the original's
//     #pos-checkout-btn handler's success path.
//   - Voiding asks for confirmation first (native confirm(), same as the
//     original's voidPosSale), then reloads the transactions table.
//
// Permission gating deferred (same as Bookings.jsx and Monitor.jsx before
// it): the original gated POS behind two permissions —
// guardPermission('pos:access', ...) before rendering the panel at all,
// and hasAdminPermission('pos:refund') to show/hide each row's Void
// button. Neither is implemented yet; there's no session role available
// client-side until AuthContext exists (Phase 10 — see this file's
// siblings for the identical note). The Void button is shown
// unconditionally for now; the server still independently enforces
// pos:refund on PUT /api/pos/sales/:id/void regardless, so a Staff account
// clicking Void today would just get the real 403 back from the server
// instead of the button never appearing — nothing is actually exposed by
// this that isn't already exposed by every other admin page so far.
// ─────────────────────────────────────────────────────────────────────────

const API_BASE_URL = 'http://localhost:3000';

function todayDateStr() {
  const d = new Date();
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
}

function fieldStyle(extra) {
  return {
    padding: '8px 10px',
    borderRadius: 8,
    border: '1px solid var(--border)',
    background: 'var(--navy3)',
    color: '#fff',
    fontFamily: "'Inter',sans-serif",
    fontSize: '.82rem',
    ...extra,
  };
}

function Pos() {
  /* ── cart / new sale ── */
  const [cart, setCart] = useState([]); // { name, price, qty }
  const [itemName, setItemName] = useState('');
  const [itemPrice, setItemPrice] = useState('');
  const [itemQty, setItemQty] = useState(1);
  const [discount, setDiscount] = useState(0);
  const [paymentMethod, setPaymentMethod] = useState('Cash');
  const [note, setNote] = useState('');
  const [checkingOut, setCheckingOut] = useState(false);

  /* ── today's transactions ── */
  const [sales, setSales] = useState([]);
  const [salesLoading, setSalesLoading] = useState(true);

  const subtotal = cart.reduce((sum, it) => sum + it.price * it.qty, 0);
  const total = Math.max(0, subtotal - (Number(discount) || 0));

  const fetchSalesToday = useCallback(async () => {
    setSalesLoading(true);
    try {
      const res = await fetch(`${API_BASE_URL}/api/pos/sales?date=${todayDateStr()}`, { credentials: 'include' });
      if (!res.ok) throw new Error('Failed to load sales.');
      const data = await res.json();
      setSales(Array.isArray(data) ? data : []);
    } catch (err) {
      console.error(err);
      setSales([]);
    } finally {
      setSalesLoading(false);
    }
  }, []);

  useEffect(() => {
    fetchSalesToday();
  }, [fetchSalesToday]);

  function addItem() {
    const name = itemName.trim();
    const price = Number(itemPrice);
    const qty = Math.max(1, parseInt(itemQty, 10) || 1);

    if (!name || !Number.isFinite(price) || price < 0) {
      alert('Enter an item name and a valid price.');
      return;
    }

    setCart((prev) => [...prev, { name, price, qty }]);
    setItemName('');
    setItemPrice('');
    setItemQty(1);
  }

  function removeItem(index) {
    setCart((prev) => prev.filter((_, i) => i !== index));
  }

  async function completeSale() {
    if (!cart.length) {
      alert('Add at least one item before completing the sale.');
      return;
    }
    setCheckingOut(true);
    try {
      const res = await fetch(`${API_BASE_URL}/api/pos/sales`, {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          items: cart.map((it) => ({ name: it.name, price: it.price, quantity: it.qty })),
          discount: Number(discount) || 0,
          paymentMethod,
          note: note.trim(),
        }),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.message || 'Failed to complete sale.');
      }
      setCart([]);
      setDiscount(0);
      setNote('');
      await fetchSalesToday();
    } catch (err) {
      alert(err.message);
    } finally {
      setCheckingOut(false);
    }
  }

  async function voidSale(id) {
    if (!confirm('Void this sale? This cannot be undone.')) return;
    try {
      const res = await fetch(`${API_BASE_URL}/api/pos/sales/${id}/void`, {
        method: 'PUT',
        credentials: 'include',
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.message || 'Failed to void sale.');
      }
      await fetchSalesToday();
    } catch (err) {
      alert(err.message);
    }
  }

  const cartRows = cart.map((it, i) => ({ ...it, _index: i }));

  return (
    <div className="panel active" id="panel-pos">
      <div className="two-col" style={{ alignItems: 'flex-start' }}>
        {/* ── New Sale ── */}
        <div className="card">
          <div className="card-head">
            <span className="card-title">New Sale</span>
          </div>
          <div style={{ display: 'flex', gap: 8, marginBottom: 10, flexWrap: 'wrap' }}>
            <input
              type="text"
              placeholder="Item name (e.g. Bottled Water)"
              value={itemName}
              onChange={(e) => setItemName(e.target.value)}
              style={fieldStyle({ flex: 2, minWidth: 160 })}
            />
            <input
              type="number"
              min="0"
              step="0.01"
              placeholder="Price"
              value={itemPrice}
              onChange={(e) => setItemPrice(e.target.value)}
              style={fieldStyle({ flex: 1, minWidth: 80 })}
            />
            <input
              type="number"
              min="1"
              step="1"
              placeholder="Qty"
              value={itemQty}
              onChange={(e) => setItemQty(e.target.value)}
              style={fieldStyle({ flex: '0 0 70px' })}
            />
            <button type="button" className="btn-teal" onClick={addItem}>
              <i className="ti ti-plus" />
              Add
            </button>
          </div>
          <div className="card" style={{ padding: 0, overflow: 'hidden' }}>
            <DataTable
              columns={[
                { key: 'name', label: 'Item' },
                { key: 'price', label: 'Price', render: (row) => `₱${row.price.toFixed(2)}` },
                { key: 'qty', label: 'Qty' },
                { key: 'subtotal', label: 'Subtotal', render: (row) => `₱${(row.price * row.qty).toFixed(2)}` },
                {
                  key: 'actions',
                  label: '',
                  render: (row) => (
                    <button type="button" className="rm-btn danger" onClick={() => removeItem(row._index)}>
                      <i className="ti ti-trash" />
                    </button>
                  ),
                },
              ]}
              rows={cartRows}
              loading={false}
              emptyMessage="Cart is empty"
              getRowKey={(row) => row._index}
            />
          </div>
        </div>

        {/* ── Checkout ── */}
        <div className="card">
          <div className="card-head">
            <span className="card-title">Checkout</span>
          </div>
          <div className="rm-row">
            <span className="lbl">Subtotal</span>
            <span className="val">₱{subtotal.toFixed(2)}</span>
          </div>
          <div className="rm-row">
            <span className="lbl">Discount</span>
            <span className="val">
              <input
                type="number"
                min="0"
                step="0.01"
                value={discount}
                onChange={(e) => setDiscount(e.target.value)}
                style={fieldStyle({ width: 90, padding: '5px 8px', borderRadius: 6, textAlign: 'right', fontSize: '.8rem' })}
              />
            </span>
          </div>
          <div className="rm-row" style={{ fontWeight: 700 }}>
            <span className="lbl">Total</span>
            <span className="val">₱{total.toFixed(2)}</span>
          </div>
          <div className="sched-field" style={{ marginTop: 10 }}>
            <label>Payment method</label>
            <select value={paymentMethod} onChange={(e) => setPaymentMethod(e.target.value)} style={fieldStyle({ width: '100%' })}>
              <option value="Cash">Cash</option>
              <option value="GCash">GCash</option>
              <option value="Maya">Maya</option>
            </select>
          </div>
          <input
            type="text"
            placeholder="Note (optional — e.g. room number)"
            value={note}
            onChange={(e) => setNote(e.target.value)}
            style={fieldStyle({ width: '100%', marginTop: 8, boxSizing: 'border-box', fontSize: '.8rem' })}
          />
          <button
            type="button"
            className="save-btn"
            style={{ width: '100%', marginTop: 12 }}
            disabled={checkingOut}
            onClick={completeSale}
          >
            <i className="ti ti-cash" /> {checkingOut ? 'Processing…' : 'Complete Sale'}
          </button>
        </div>
      </div>

      {/* ── Today's Transactions ── */}
      <div className="card" style={{ padding: 0, overflow: 'hidden', overflowX: 'auto' }}>
        <div className="card-head" style={{ padding: '12px 14px 0' }}>
          <span className="card-title">Today's Transactions</span>
        </div>
        <DataTable
          columns={[
            {
              key: 'time',
              label: 'Time',
              render: (row) => new Date(row.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
            },
            {
              key: 'items',
              label: 'Items',
              render: (row) => row.items.map((it) => `${it.name} ×${it.quantity}`).join(', '),
            },
            { key: 'total', label: 'Total', render: (row) => `₱${row.total.toFixed(2)}` },
            { key: 'paymentMethod', label: 'Payment' },
            {
              key: 'cashier',
              label: 'Cashier',
              render: (row) => (row.cashier ? [row.cashier.firstname, row.cashier.lastname].filter(Boolean).join(' ') : '—'),
            },
            {
              key: 'status',
              label: 'Status',
              render: (row) =>
                row.status === 'Voided' ? (
                  <span className="pill pill-pending">Voided</span>
                ) : (
                  <span className="pill pill-active">Completed</span>
                ),
            },
            {
              key: 'actions',
              label: 'Actions',
              render: (row) =>
                row.status !== 'Voided' ? (
                  <button type="button" className="rm-btn danger" onClick={() => voidSale(row._id)}>
                    Void
                  </button>
                ) : (
                  <span style={{ fontSize: '.7rem', color: 'var(--muted)' }}>—</span>
                ),
            },
          ]}
          rows={sales}
          loading={salesLoading}
          emptyMessage="No sales yet today."
          getRowKey={(row) => row._id}
        />
      </div>
    </div>
  );
}

export default Pos;
